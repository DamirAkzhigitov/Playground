{
  "name": "playground",
  "version": "1.0.0",
  "description": "Damir Akzhigitov — monorepo for da-mr.com and subdomain tools",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "preview": "turbo run preview",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:staged": "lint-staged",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "type-check": "turbo run type-check",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "security:audit": "pnpm audit --audit-level=moderate",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.5.0",
    "turbo": "2.9.12"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md,html}": "pnpm exec prettier --write"
  }
}
