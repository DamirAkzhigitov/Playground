{
  "name": "@playground/apartments-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "db:migrate:local": "wrangler d1 migrations apply apartments-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply apartments-db --remote",
    "db:migrate:remote:dev": "wrangler d1 migrations apply apartments-db-dev --remote --env dev",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.7.11",
    "xlsx": "0.18.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250508.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.21.0"
  }
}
