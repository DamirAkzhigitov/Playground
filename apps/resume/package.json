{
  "name": "@playground/resume",
  "version": "1.0.0",
  "description": "Damir Akzhigitov resume app (static site)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "format:check": "prettier --ignore-path ../../.prettierignore --check .",
    "type-check": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@playground/global-header": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.19.7",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "9.39.2",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-security": "1.7.1",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  }
}
