{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": [
        "VITE_MAIN_ORIGIN",
        "VITE_RESUME_ORIGIN",
        "VITE_APARTMENTS_ORIGIN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {},
    "type-check": {},
    "test": {},
    "test:coverage": {
      "outputs": ["coverage/**"]
    }
  }
}
