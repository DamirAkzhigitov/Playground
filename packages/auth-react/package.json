{
  "name": "@playground/auth-react",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared React auth UI and session context for da-mr.com tools",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "format:check": "prettier --ignore-path ../../.prettierignore --check .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0"
  },
  "peerDependencies": {
    "lucide-react": ">=1.14.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-router-dom": ">=7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
